    let board = names.map((n, i) => ({ name: n, xp: Math.floor(Math.random() * 7000) + 500, emoji: emojis[i] }));
    board.push({ name: state.lang === 'it' ? "Tu (Hunter)" : "You (Hunter)", xp: state.xp, emoji: "🐝", isMe: true });
    board.sort((a, b) => b.xp - a.xp);

    const medals = ['🥇', '🥈', '🥉'];
    document.getElementById('leaderboard-container').innerHTML = board.map((user, i) => `
        <div class="leader-row ${user.isMe ? 'bg-yellow-50' : ''}">
            <div class="flex items-center gap-3">
                <span class="text-base w-6 text-center">${i < 3 ? medals[i] : `<span class="text-xs font-black text-slate-400">${i+1}</span>`}</span>
                <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center text-sm">${user.emoji}</div>
                <span class="text-sm ${user.isMe ? 'font-black text-blue-600' : 'font-bold'}">${user.name}</span>
            </div>
            <span class="text-xs font-black text-purple-600">${user.xp.toLocaleString()} XP</span>
        </div>`).join('');
}

/* ===================== RENDER HISTORY ===================== */
function renderHistory() {
    const container = document.getElementById('history-container');
    if (state.history.length === 0) {
        container.innerHTML = `<div class="text-center py-10 text-slate-400"><i class="fa-solid fa-clock-rotate-left text-3xl mb-3 block"></i><p class="font-bold">Nessuna attività ancora</p><p class="text-xs mt-1">Inizia a esplorare!</p></div>`;
        return;
    }
    container.innerHTML = [...state.history].reverse().slice(0, 50).map(h => `
        <div class="history-item">
            <p class="font-black text-sm">${h.name}</p>
            <p class="text-xs text-slate-500">${h.date}</p>
            <span class="text-xs font-black text-blue-600">+${h.xp} XP</span>
        </div>`).join('');
}

/* ===================== RENDER CHALLENGES ===================== */
function renderChallenges() {
    const container = document.getElementById('challenges-container');
    const today = new Date().toDateString();
    container.innerHTML = DB.challenges.map(ch => {
        const progress = state.challengeProgress[ch.id] || 0;
        const pct = Math.min(100, (progress / ch.target) * 100);
        const done = progress >= ch.target;
        return `
        <div class="card-pro ${done ? 'opacity-70' : ''}">
            <div class="flex items-start gap-3">
                <div class="text-3xl">${ch.emoji}</div>
                <div class="flex-1">
                    <div class="flex justify-between items-start">
                        <h3 class="font-black text-sm">${ch[state.lang].name}</h3>
                        <span class="text-xs font-black text-blue-600">+${ch.xp} XP</span>
                    </div>
                    <p class="text-xs text-slate-500 mb-2">${ch[state.lang].desc}</p>
                    <div class="xp-bar-bg mb-1"><div class="xp-bar-fill" style="width:${pct}%"></div></div>
                    <div class="flex justify-between text-[10px] text-slate-400 font-bold">
                        <span>${progress}/${ch.target}</span>
                        <span>${done ? '✅ Completata!' : 'In corso...'}</span>
                    </div>
                </div>
            </div>
        </div>`;
    }).join('');
}

/* ===================== SCANNER AR ===================== */
let videoStream = null;

function openScanner(pointId) {
    currentScanPointId = pointId;
    const p = DB.points.find(x => x.id === pointId);
    if (p) document.querySelector('#ar-point-name p').textContent = p[state.lang].name;
    document.getElementById('ar-scanner').style.display = 'block';
    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
            .then(stream => { videoStream = stream; document.getElementById('ar-video').srcObject = stream; })
            .catch(() => { /* Camera non disponibile, funziona comunque */ });
    }
}

function closeScanner() {
    document.getElementById('ar-scanner').style.display = 'none';
    if (videoStream) { videoStream.getTracks().forEach(t => t.stop()); videoStream = null; }
    currentScanPointId = null;
}

function validatePoint() {
    const id = currentScanPointId;
    if (!id) return;
    const p = DB.points.find(x => x.id === id);
    if (!p || state.visited.includes(id)) { closeScanner(); return; }

    // Simulazione validazione (1.5s)
    document.querySelector('.ar-laser').style.background = 'linear-gradient(90deg, transparent, #22C55E, transparent)';
    setTimeout(() => {
        state.xp += p.xp;
        state.visited.push(id);
        state.history.push({ id: p.id, name: p[state.lang].name, xp: p.xp, date: new Date().toLocaleString(state.lang === 'it' ? 'it-IT' : 'en-US') });

        // Aggiorna sfide
        updateChallengeProgress('visit_any');
        updateChallengeProgress(`visit_${p.type}`);

        checkAchievements();
        saveState();
        closeScanner();
        renderAll();
        showToast(`✅ ${t('msg-claimed')}${p.xp} XP · ${p[state.lang].name}`, 'success');
    }, 1500);
}

/* ===================== AZIONI UTENTE ===================== */
function bookTour(tourId) {
    const tour = DB.tours.find(x => x.id === tourId);
    if (!tour || state.completedTours.includes(tourId)) return;
    state.xp += tour.xp;
    state.completedTours.push(tourId);
    if (!state.badges.includes(tour.badge)) {
        state.badges.push(tour.badge);
        showToast(`${t('msg-badge')} ${tour.badge}`, 'badge');
    }
    state.history.push({ id: tour.id, name: tour[state.lang].name, xp: tour.xp, date: new Date().toLocaleString(state.lang === 'it' ? 'it-IT' : 'en-US') });
    checkAchievements();
    saveState();
    renderAll();
    showToast(`🗺️ Tour Completato! +${tour.xp} XP`, 'success');
}

function redeemCoupon(id, cost) {
    if (state.xp < cost) { showToast(t('msg-xp-low'), 'error'); return; }
    state.xp -= cost;
    state.unlockedCoupons.push(id);
    saveState();
    renderAll();
    showToast(t('msg-redeemed'), 'success');
}

function buyPremiumXP() {
    state.xp += 2000;
    checkAchievements();
    saveState();
    renderAll();
    showToast(t('msg-purchased'), 'success');
}

function buyHunterPass() {
    state.xp += 500;
    showToast('👑 Hunter Pass attivato! +500 XP bonus', 'success');
    saveState();
    renderAll();
}

function shareSocialAndGetBonus(nomeLuogo) {
    const testo = state.lang === 'it'
        ? `Ho appena esplorato ${nomeLuogo} su BeeHunter Puglia! 🐝 Unisciti alla caccia! #BeeHunterPuglia`
        : `I just explored ${nomeLuogo} on BeeHunter Puglia! 🐝 Join the hunt! #BeeHunterPuglia`;

    state.shares = (state.shares || 0) + 1;
    updateChallengeProgress('share');

    if (navigator.share) {
        navigator.share({ title: 'BeeHunter Puglia', text: testo, url: window.location.href })
            .then(() => { state.xp += 5; saveState(); updateHeader(); showToast(t('msg-share'), 'success'); });
    } else {
        navigator.clipboard.writeText(testo).then(() => showToast('📋 Testo copiato! +5 XP', 'success')).catch(() => {});
        state.xp += 5; saveState(); updateHeader();
    }
    checkAchievements();
}

function shareApp() {
    const testo = state.lang === 'it' ? 'Scopri BeeHunter Puglia! 🐝 L\'app per esplorare la Puglia guadagnando XP!' : 'Discover BeeHunter Puglia! 🐝 The app to explore Puglia while earning XP!';
    if (navigator.share) { navigator.share({ title: 'BeeHunter Puglia', text: testo, url: window.location.href }); }
    else { navigator.clipboard.writeText(testo).then(() => showToast('📋 Link copiato!', 'success')).catch(() => {}); }
}

/* ===================== ACHIEVEMENTS ===================== */
function checkAchievements() {
    const addBadge = (id) => {
        if (!state.badges.includes(id)) {
            state.badges.push(id);
            showToast(`${t('msg-badge')} ${id}`, 'badge');
            return true;
        }
        return false;
    };

    const foodVisits   = state.visited.filter(vid => { const p = DB.points.find(x => x.id === vid); return p && p.type === 'Food'; }).length;
    const seaVisits    = state.visited.filter(vid => { const p = DB.points.find(x => x.id === vid); return p && p.type === 'Natura'; }).length;
    const eventVisits  = state.visited.filter(vid => { const p = DB.points.find(x => x.id === vid); return p && p.type === 'Eventi'; }).length;
    const cultVisits   = state.visited.filter(vid => { const p = DB.points.find(x => x.id === vid); return p && p.type === 'Cultura'; }).length;
    const secretVisits = state.visited.filter(vid => { const p = DB.points.find(x => x.id === vid); return p && p.type === 'Segreto'; }).length;

    if (foodVisits   >= 5)  addBadge("Foodie Hunter");
    if (seaVisits    >= 5)  addBadge("Sea Hunter");
    if (eventVisits  >= 3)  addBadge("Event Collector");
    if (cultVisits   >= 5)  addBadge("Heritage Seeker");
    if (secretVisits >= 1)  addBadge("Secret Finder");
    if (state.xp     >= 5000) addBadge("Master Hunter");
    if (state.visited.length >= 20) addBadge("Ultimate Explorer");
    if ((state.shares || 0) >= 5) addBadge("Social Butterfly");
    if (state.streak >= 7)  addBadge("Streak Master");
}

function updateChallengeProgress(type) {
    DB.challenges.forEach(ch => {
        if (ch.type === type || ch.type === 'visit_any') {
            if (ch.type === type || type === 'visit_any') {
                state.challengeProgress[ch.id] = (state.challengeProgress[ch.id] || 0) + 1;
                if (state.challengeProgress[ch.id] === ch.target) {
                    state.xp += ch.xp;
                    showToast(`🎯 Sfida completata: ${ch[state.lang].name} +${ch.xp} XP`, 'success');
                }
            }
        }
    });
}

/* ===================== STREAK GIORNALIERO ===================== */
function updateStreak() {
    const today = new Date().toDateString();
    const lastLogin = state.lastLogin ? new Date(state.lastLogin).toDateString() : null;
    const yesterday = new Date(Date.now() - 86400000).toDateString();

    if (lastLogin === today) return; // Già aggiornato oggi
    if (lastLogin === yesterday) {
        state.streak = (state.streak || 0) + 1;
        if (state.streak % 7 === 0) showToast(`🔥 Streak di ${state.streak} giorni! Bonus +50 XP`, 'success');
        if (state.streak % 7 === 0) state.xp += 50;
    } else if (lastLogin !== today) {
        state.streak = 1; // Reset streak
    }
    state.lastLogin = new Date().toISOString();
    saveState();
}

/* ===================== METEO (Open-Meteo, free, no key) ===================== */
async function fetchWeather() {
    try {
        const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=41.1171&longitude=16.8719&current=temperature_2m,weathercode,relative_humidity_2m&timezone=Europe/Rome');
        const data = await res.json();
        const temp = Math.round(data.current.temperature_2m);
        const code = data.current.weathercode;
        const humidity = data.current.relative_humidity_2m;

        const weatherMap = {
            0: { desc: state.lang === 'it' ? 'Sereno' : 'Clear sky', icon: 'fa-sun', color: '#F59E0B' },
            1: { desc: state.lang === 'it' ? 'Prevalentemente sereno' : 'Mainly clear', icon: 'fa-sun', color: '#F59E0B' },
            2: { desc: state.lang === 'it' ? 'Parzialmente nuvoloso' : 'Partly cloudy', icon: 'fa-cloud-sun', color: '#94A3B8' },
            3: { desc: state.lang === 'it' ? 'Nuvoloso' : 'Overcast', icon: 'fa-cloud', color: '#94A3B8' },
            45: { desc: state.lang === 'it' ? 'Nebbia' : 'Foggy', icon: 'fa-smog', color: '#94A3B8' },
            51: { desc: state.lang === 'it' ? 'Pioggerella' : 'Drizzle', icon: 'fa-cloud-drizzle', color: '#60A5FA' },
            61: { desc: state.lang === 'it' ? 'Pioggia' : 'Rain', icon: 'fa-cloud-rain', color: '#3B82F6' },
            71: { desc: state.lang === 'it' ? 'Neve' : 'Snow', icon: 'fa-snowflake', color: '#BAE6FD' },
            80: { desc: state.lang === 'it' ? 'Rovesci' : 'Showers', icon: 'fa-cloud-showers-heavy', color: '#3B82F6' },
            95: { desc: state.lang === 'it' ? 'Temporale' : 'Thunderstorm', icon: 'fa-bolt', color: '#7C3AED' }
        };

        const w = weatherMap[code] || weatherMap[0];
        document.getElementById('w-temp').textContent = `${temp}°C`;
        document.getElementById('w-desc').textContent = w.desc;
        document.getElementById('w-humidity').textContent = `${state.lang === 'it' ? 'Umidità' : 'Humidity'}: ${humidity}%`;
        document.getElementById('w-icon').className = `fa-solid ${w.icon} text-4xl opacity-90`;
    } catch (e) {
        document.getElementById('w-desc').textContent = state.lang === 'it' ? 'Meteo non disponibile' : 'Weather unavailable';
    }
}

/* ===================== NAVIGAZIONE ===================== */
function nav(id, el) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    if (el) el.classList.add('active');
    if (id === 'radar') setTimeout(() => map.invalidateSize(), 300);
    if (id === 'social') { generateFakeLeaderboard(); renderHistory(); renderChallenges(); }
    if (id === 'profile') renderProfile();
    if (id === 'shop') renderCoupons();
    if (id === 'tours') renderTours();
}

function switchSocialTab(tab) {
    ['board', 'history', 'challenges'].forEach(t => {
        document.getElementById(`view-${t}`).style.display = t === tab ? 'block' : 'none';
        const btn = document.getElementById(`tab-${t}`);
        if (btn) btn.className = t === tab
            ? 'flex-1 bg-white shadow-sm py-2 rounded-lg font-black text-xs'
            : 'flex-1 py-2 rounded-lg font-black text-xs text-slate-400';
    });
    if (tab === 'board') generateFakeLeaderboard();
    if (tab === 'history') renderHistory();
    if (tab === 'challenges') renderChallenges();
}

/* ===================== MENU LATERALE ===================== */
function toggleMenu() {
    const menu = document.getElementById('side-menu');
    const overlay = document.getElementById('menu-overlay');
    const isOpen = menu.classList.contains('open');
    menu.classList.toggle('open', !isOpen);
    overlay.style.display = isOpen ? 'none' : 'block';
}

/* ===================== LINGUA ===================== */
function toggleLang() {
    state.lang = state.lang === 'it' ? 'en' : 'it';
    saveState();
    applyTranslations();
    renderAll();
    fetchWeather();
}

function applyTranslations() {
    const dict = I18N[state.lang];
    for (let key in dict) {
        document.querySelectorAll(`.${key}`).forEach(el => el.innerText = dict[key]);
    }
}

/* ===================== UTILITY ===================== */
function getCurrentRank() {
    let rank = RANKS[0];
    for (const r of RANKS) { if (state.xp >= r.xp) rank = r; }
    return rank;
}

function getNextRank() {
    for (const r of RANKS) { if (state.xp < r.xp) return r; }
    return null;
}

function updateHeader() {
    const rank = getCurrentRank();
    const nextRank = getNextRank();
    const progress = nextRank ? Math.min(100, ((state.xp - rank.xp) / (nextRank.xp - rank.xp)) * 100) : 100;
    document.getElementById('total-xp').textContent = `${state.xp.toLocaleString()} XP`;
    document.getElementById('h-rank').textContent = (state.lang === 'it' ? rank.name : rank.nameEn).toUpperCase();
    document.getElementById('xp-bar').style.width = `${progress}%`;
}

function t(key) { return I18N[state.lang][key] || key; }

function showToast(msg, type = 'info') {
    const icons = { success: 'fa-circle-check text-green-400', error: 'fa-circle-xmark text-red-400', badge: 'fa-shield-halved text-yellow-400', info: 'fa-bell text-yellow-400' };
    const tBox = document.getElementById('toast-box');
    document.getElementById('toast-msg').innerText = msg;
    document.getElementById('toast-icon').className = `fa-solid ${icons[type] || icons.info} text-lg flex-shrink-0`;
    tBox.style.display = 'block';
    tBox.className = 'animate__animated animate__fadeInDown';
    clearTimeout(tBox._timeout);
    tBox._timeout = setTimeout(() => {
        tBox.className = 'animate__animated animate__fadeOutUp';
        setTimeout(() => { tBox.style.display = 'none'; }, 500);
    }, 3500);
}

/* ===================== PERSISTENZA ===================== */
function saveState() { try { localStorage.setItem('beehunter_v2', JSON.stringify(state)); } catch(e) {} }

function loadState() {
    try {
        const saved = localStorage.getItem('beehunter_v2');
        if (saved) state = { ...DEFAULT_STATE, ...JSON.parse(saved) };
    } catch(e) { state = { ...DEFAULT_STATE }; }
}

function resetProgress() {
    if (!confirm('Sei sicuro di voler resettare tutti i progressi?')) return;
    state = { ...DEFAULT_STATE };
    saveState();
    renderAll();
    showToast('🔄 Progressi resettati', 'info');
}

function exportData() {
    const data = {
        xp: state.xp, visited: state.visited.length, badges: state.badges,
        tours: state.completedTours, history: state.history.slice(-20)
    };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = 'beehunter_data.json'; a.click();
    URL.revokeObjectURL(url);
}

/* ===================== OFFLINE DETECTION ===================== */
function setupOfflineDetection() {
    const banner = document.getElementById('offline-banner');
    window.addEventListener('offline', () => { banner.style.display = 'block'; });
    window.addEventListener('online',  () => { banner.style.display = 'none'; });
    if (!navigator.onLine) banner.style.display = 'block';
}

/* ===================== RENDER ALL ===================== */
function renderAll() {
    updateHeader();
    renderPoints();
    renderMapMarkers();
    renderTours();
    renderCoupons();
    renderProfile();
}

/* ===================== INIT ===================== */
function init() {
    loadState();
    updateStreak();
    initMap();
    applyTranslations();
    renderAll();
    fetchWeather();
    setupOfflineDetection();
    generateFakeLeaderboard();

    // Aggiorna meteo ogni 10 minuti
    setInterval(fetchWeather, 600000);

    // Benvenuto al primo avvio
    if (state.visited.length === 0 && state.xp === 0) {
        setTimeout(() => showToast('🐝 Benvenuto in BeeHunter Puglia! Inizia a esplorare!', 'info'), 1000);
    }
}

window.onload = init;
</script>

const DEFAULT_STATE = {
    xp: 0, lang: 'it', visited: [], badges: [], history: [],
    unlockedCoupons: [], completedTours: [], shares: 0,
    streak: 0, lastLogin: null, challengeProgress: {},
    currentFilter: 'all', searchQuery: ''
};

let state = { ...DEFAULT_STATE };

/* ===================== MAPPA LEAFLET ===================== */
let map, markerCluster;
let currentScanPointId = null;

function initMap() {
    map = L.map('map', { zoomControl: false, attributionControl: false }).setView([41.1171, 16.8719], 9);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '© OpenStreetMap © CARTO', maxZoom: 19
    }).addTo(map);
    L.control.zoom({ position: 'bottomright' }).addTo(map);
    markerCluster = L.markerClusterGroup({ maxClusterRadius: 50, showCoverageOnHover: false });
    map.addLayer(markerCluster);
}

function renderMapMarkers() {
    markerCluster.clearLayers();
    const filtered = getFilteredPoints();
    filtered.forEach(p => {
        const icon = L.divIcon({
            className: '',
            html: `<div class="marker-base marker-icon-${p.type}">${getTypeIcon(p.type)}</div>`,
            iconSize: [32, 32], iconAnchor: [16, 16]
        });
        const marker = L.marker([p.lat, p.lng], { icon });
        marker.on('click', () => openPointModal(p.id));
        if (state.visited.includes(p.id)) {
            marker.setOpacity(0.5);
        }
        markerCluster.addLayer(marker);
    });
}

function getTypeIcon(type) {
    const icons = { Cultura: '🏛️', Natura: '🌿', Food: '🍕', Eventi: '🎉', Segreto: '🔍' };
    return icons[type] || '📍';
}

/* ===================== FILTRI E RICERCA ===================== */
function setFilter(cat, el) {
    state.currentFilter = cat;
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    renderPoints();
    renderMapMarkers();
}

function filterPoints() {
    const q = document.getElementById('search-input').value;
    state.searchQuery = q;
    document.getElementById('search-clear').classList.toggle('hidden', !q);
    renderPoints();
}

function clearSearch() {
    document.getElementById('search-input').value = '';
    state.searchQuery = '';
    document.getElementById('search-clear').classList.add('hidden');
    renderPoints();
}

function getFilteredPoints() {
    let pts = DB.points;
    if (state.currentFilter !== 'all') pts = pts.filter(p => p.type === state.currentFilter);
    if (state.searchQuery) {
        const q = state.searchQuery.toLowerCase();
        pts = pts.filter(p => p[state.lang].name.toLowerCase().includes(q) || p[state.lang].desc.toLowerCase().includes(q));
    }
    return pts;
}


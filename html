function renderProfile() {
    const rank = getCurrentRank();
    const nextRank = getNextRank();
    const progress = nextRank ? Math.min(100, ((state.xp - rank.xp) / (nextRank.xp - rank.xp)) * 100) : 100;

    document.getElementById('u-name').textContent = state.lang === 'it' ? rank.name : rank.nameEn;
    document.getElementById('u-tier').textContent = (state.lang === 'it' ? rank.name : rank.nameEn).toUpperCase();
    document.getElementById('stat-places').textContent = state.visited.length;
    document.getElementById('stat-badges').textContent = state.badges.length;
    document.getElementById('stat-tours').textContent = state.completedTours.length;
    document.getElementById('profile-xp-bar').style.width = `${progress}%`;
    document.getElementById('xp-current-label').textContent = `${state.xp} XP`;
    document.getElementById('xp-next-label').textContent = nextRank ? `${nextRank.xp} XP` : 'MAX';
    document.getElementById('streak-count').innerHTML = `${state.streak} <span class="text-base">🔥</span>`;
    document.getElementById('last-login').textContent = state.lastLogin ? new Date(state.lastLogin).toLocaleDateString(state.lang === 'it' ? 'it-IT' : 'en-US') : '--';

